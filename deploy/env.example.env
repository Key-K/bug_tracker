SCOUT_PORT=10009
SCOUT_JWT_SECRET=<CHANGE-ME-strong-random-secret>
SCOUT_DB_PATH=data/scout.db
SCOUT_CORS_ORIGINS=https://<CHANGE-ME-domain>

# Optional: enable Scout's own dashboard widget and report into this project slug
# SCOUT_DASHBOARD_WIDGET_PROJECT_SLUG=scout

# Optional email delivery
# SCOUT_GRAFANA_URL=https://<CHANGE-ME-grafana-domain>
# SMTP_HOST=<CHANGE-ME-smtp-host>
# SMTP_PORT=587
# SMTP_USER=<CHANGE-ME-smtp-user>
# SMTP_PASS=<CHANGE-ME-smtp-password>
# SMTP_FROM=<CHANGE-ME-from-address>
# SMTP_SECURE=false
# SCOUT_PUBLIC_URL=https://<CHANGE-ME-domain>
# SCOUT_DAILY_DIGEST_ENABLED=true
# SCOUT_DAILY_DIGEST_TIME=18:00
# SCOUT_DAILY_DIGEST_TIMEZONE=Asia/Almaty

LOG_LEVEL=info
